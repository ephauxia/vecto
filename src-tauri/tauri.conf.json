  },
  "productName": "VECTO",
  "mainBinaryName": "VECTO",
  "version": "1.0.0",
  "identifier": "com.vecto.player",
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "visible": false,
        "fullscreen": false,
        "resizable": true,
