{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "../src",
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "category": "Entertainment",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "certificateThumbprint": null,
